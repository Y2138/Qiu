generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  apiKeys   ApiKey[]
  sessions  Session[]
  files     File[]
  agentRuns AgentRun[]
  agentMemoryEntries AgentMemoryEntry[]
}

// API Key
model ApiKey {
  id            String    @id @default(cuid())
  userId        String
  name          String    // 自定义配置名称
  apiType       String    // openai, anthropic
  baseUrl       String    // API 基础地址
  encryptedKey  String    // 加密的 API Key
  models        String[]  // 支持的模型列表
  isActive      Boolean   @default(true)
  testResult    Json?     // API Key 测试结果
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 会话
model Session {
  id        String    @id @default(cuid())
  userId    String
  title     String
  model     String    // 当前使用的模型
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // 关系
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  files     File[]
  agentRuns AgentRun[]
  agentMemoryEntries AgentMemoryEntry[]

  @@index([userId])
  @@index([updatedAt])
}

// 消息
model Message {
  id        String    @id @default(cuid())
  sessionId String
  role      String    // user, assistant, system
  content   String
  model     String?   // 使用的模型
  tokens    Int?      // 消耗的 token 数
  metadata  Json?     // 额外元数据
  createdAt DateTime  @default(now())

  // 关系
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// 文件
model File {
  id             String    @id @default(cuid())
  userId         String
  sessionId      String?
  fileName       String
  originalName   String
  fileType       String    // MIME type
  fileSize       Int
  storageKey     String    // 存储路径或 key
  extractedContent String? // 提取的文本内容
  metadata       Json?
  createdAt      DateTime  @default(now())

  // 关系
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  session        Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
}

model AgentRun {
  id                     String            @id
  sessionId              String
  userId                 String
  status                 String
  goal                   String?
  memoryMode             String
  allowMcp               Boolean           @default(false)
  maxSteps               Int               @default(4)
  promptPresetIds        String[]          @default([])
  stopReason             String?
  resumedFromCheckpointId String?
  latestCheckpointId     String?
  metadata               Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  session                Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkpoints            AgentCheckpoint[] @relation("RunCheckpoints")
  resumedFromCheckpoint  AgentCheckpoint?  @relation("ResumedFromCheckpoint", fields: [resumedFromCheckpointId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  latestCheckpoint       AgentCheckpoint?  @relation("LatestCheckpoint", fields: [latestCheckpointId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([sessionId, updatedAt])
  @@index([userId, updatedAt])
  @@index([status, updatedAt])
}

model AgentCheckpoint {
  id               String      @id
  runId            String
  status           String
  stopReason       String
  goal             String?
  stepCount        Int?
  messagesSnapshot Json?
  memorySummary    Json?
  observations     Json?
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  run              AgentRun    @relation("RunCheckpoints", fields: [runId], references: [id], onDelete: Cascade)
  resumedByRuns    AgentRun[]  @relation("ResumedFromCheckpoint")
  latestForRuns    AgentRun[]  @relation("LatestCheckpoint")

  @@index([runId, createdAt])
  @@index([status, createdAt])
}

model AgentMemoryEntry {
  id         String    @id
  userId     String
  sessionId  String?
  scope      String
  kind       String
  content    String
  source     String
  metadata   Json?
  updatedAt  DateTime
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    Session?  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, scope, updatedAt])
  @@index([sessionId, scope, updatedAt])
}

model ChatRequestLog {
  id               String   @id @default(cuid())
  requestId        String   @unique
  userId           String?
  sessionId        String?
  apiKeyId         String?
  provider         String?
  model            String?
  stream           Boolean?
  requestMode      String?
  status           String
  durationMs       Int?
  startedAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  llmRequest       Json?
  llmResponse      Json?
  error            Json?

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([provider, model, createdAt])
  @@index([createdAt])
}
